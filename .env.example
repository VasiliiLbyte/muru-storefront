# Базовый URL API-клиента (src/lib/api): каталог, CDEK, payments.
# Дев и тесты работают на MSW — оставь пустым (запросы идут по относительным путям
# /categories, /products, ... которые перехватывает MSW-воркер).
# В prod достаточно одной переменной: каталог и чекаут используют её как fallback.
# Пример для реального API: https://api.muru.ru
NEXT_PUBLIC_API_BASE=

# Каталог (опционально). Если пусто — используется NEXT_PUBLIC_API_BASE.
# Пример: http://localhost:4000/api
NEXT_PUBLIC_CATALOG_API_BASE=

# Базовый URL для CMS-изображений (/uploads/*). Опционален:
# по умолчанию = NEXT_PUBLIC_API_BASE без суффикса "/api".
# Пример для web.murushop.ru: https://murushop.ru
NEXT_PUBLIC_ASSETS_BASE=

# MSW-моки. "enabled" — принудительно включить моки (browser worker + node server).
# В development моки включены автоматически и без этого флага.
# Для работы против реального backend — оставь пустым / убери в проде.
NEXT_PUBLIC_API_MOCKING=enabled

# Server-only upstream for account BFF (/api/account/* → ${MURU_API_BASE}/account/*).
# Falls back to NEXT_PUBLIC_API_BASE if unset. Never expose CUSTOMER_JWT_SECRET here.
# Example: http://localhost:4000/api
MURU_API_BASE=

# Yandex SmartCaptcha client key (W3 UI). Server key stays on the backend only.
NEXT_PUBLIC_SMARTCAPTCHA_CLIENT_KEY=
